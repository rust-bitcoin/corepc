# Thin wrapper over the `btc-codegen` crate beside this file.

default:
    @just --list

# Generate bindings for one Core version (`just codegen 30`), or `clean` to remove them.
codegen version:
    if [ "{{version}}" = "clean" ]; then just -f "{{justfile()}}" clean; else cargo run --bin btc-codegen --release --quiet -- {{version}}; fi

# Generate bindings for every spec in specs/.
codegen-all:
    cargo run --bin btc-codegen --release --quiet -- all

# Delete the generator-owned trees (types/src/v*/generated/ and generated client dirs).
# Hand-written files are left untouched.
clean:
    #!/usr/bin/env bash
    set -euo pipefail
    root="$(git rev-parse --show-toplevel)"
    rm -rf "$root"/types/src/v*/generated
    for d in "$root"/client/src/client_async/v*/; do
        if [ -f "$d/mod.rs" ] && grep -q 'Generated by `codegen`' "$d/mod.rs"; then
            rm -rf "$d"
        fi
    done
    echo "removed generated code"
